@model IEnumerable<CrudDemo.Models.Product>
@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Products</h1>
    <a class="btn btn-primary" href="/Products/Create">Create New</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Price</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Price.ToString("C")</td>
            <td>
                <a class="btn btn-sm btn-secondary" href="/Products/Details/@item.Id">Details</a>
                <a class="btn btn-sm btn-success" href="/Products/Edit/@item.Id">Edit</a>
                <a class="btn btn-sm btn-danger" href="/Products/Delete/@item.Id">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
